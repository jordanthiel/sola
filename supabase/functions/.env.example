# Loaded automatically by `supabase functions serve` and `supabase start`
RESEND_API_KEY=re_xxxx

# Optional — only needed if the runtime does not inject them (e.g. custom --env-file)
# SUPABASE_URL=http://127.0.0.1:55321
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Optional sender override (default: Sova Home <hello@sova.baby>)
# EMAIL_FROM=Sova Home <hello@sova.baby>

# NannyKeeper household payroll (paid tier) — https://www.nannykeeper.com/developers/keys
# NANNYKEEPER_API_KEY=nk_live_xxx
